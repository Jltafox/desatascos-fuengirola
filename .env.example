# Copia este archivo a `.env` (sin .example) y rellena los valores.
# .env está en .gitignore y NO se sube a GitHub.

# Clave de API de OpenAI (para generar imágenes con gpt-image-1).
# Obtén una en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Solo en local: descomenta para probar la protección por contraseña.
# PREVIEW_USER=cliente
# PREVIEW_PASSWORD=secreto
